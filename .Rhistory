library(readr)
case0502new <- read_csv("C:/Users/auuser/Downloads/spock0502 (1).csv")
View(case0502new)
library(DescTools)
library(mosaic)
library(ggthemes)
library(gmodels)
library(tidyverse)
class(case0502new$Other)
# make sure to change all 3 of the categorical variables that you'll be using in ANOVA as factors (Judge, Comb, Other)
# For example:
case0502new$Other <- as.factor(case0502new$Other)
case0502new$Judge <- as.factor(case0502new$Judge)
case0502new$Comb <- as.factor(case0502new$Comb)
ggplot(case0502new, aes(x = Judge, y = Percent)) +
geom_boxplot(fill = "green")
case0502new %>%
mutate(Judge = fct_reorder(Judge, Percent, .fun = 'median')) %>%
ggplot(aes(x = Judge, y = Percent))+
geom_boxplot(aes(fill = Judge), show.legend = FALSE) +
coord_flip()+
labs (title = "Percent of women in 30-juror venires for Boston",
y = "Percent of women", x = "Judges")
case0502new %>%
group_by(Judge) %>%
summarise(n = n(), Average = mean(Percent), Median = median(Percent),
SD = sd(Percent),  IQR = IQR(Percent),
Min = min(Percent), Max = max(Percent)) %>%
knitr::kable(digits = 2)
model.fit <- aov(Percent~Judge, data = case0502new)
anova(model.fit)
PostHocTest(model.fit, method = "lsd")
################ His pools have smaller percentages of women than the pools of each of the other judges.
################ Every pairwise comparison between Spock and another Judge is sig different at at least the 0.05 alpha level.
# 8. How do your results and conclusion change when you adjust for multiple comparisons
PostHocTest(model.fit, method = "bonferroni")
################  The difference between Spock's pools and the other Judges are still statistically significant with
################     with the exception of judge D which is no longer significant when adjusting for multiple comparisons
