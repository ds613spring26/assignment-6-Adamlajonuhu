#| label: extract-data
# 1. Define
# 2. Submit
# 3. Wait & Download
# 4. Read
extract <- define_extract_nhgis(
description = "1990 STF1 NP1 State Population Status (STATE)",
datasets = ds_spec("1990_STF1", data_tables = "NP1"),
geog_levels = "state"
)
extract <- define_extract_agg(
"nhgis",
description = "1990 STF1 NP1 State-level",
datasets = ds_spec(
"1990_STF1",             # dataset name
data_tables = "NP1",     # table you want
geog_levels = "state"    # geography here
)
)
extract <- submit_extract(extract)
extract <- wait_for_extract(extract)
extract_downloaded <- download_extract(extract)
nhgis_raw <- read_nhgis(extract_downloaded)
glimpse(nhgis_raw)
head(nhgis_raw)
nhgis_clean <- nhgis_raw %>%
rename(
gisjoin    = GISJOIN,
year       = YEAR,
state_abbr = STUSAB,
division   = DIVISIONA,
region     = REGIONA,
state_name = STATE,
state_code = STATEA,
land_area  = AREALAND,
water_area = AREAWAT,
total_pop  = ET1001
) %>%
select(
gisjoin, year, state_abbr, division, region,
state_name, state_code, land_area, water_area, total_pop
)
glimpse(nhgis_clean)
nhgis_clean <- nhgis_clean %>%
mutate(pop_density = total_pop / land_area)
str(nhgis_clean)
nhgis_clean <- nhgis_clean %>%
mutate(
total_pop = as.numeric(total_pop),
land_area = as.numeric(land_area),
water_area = as.numeric(water_area)
)
nhgis_clean <- nhgis_clean %>%
mutate(pop_density = total_pop / land_area)
nhgis_clean %>%
select(state_name, state_abbr, total_pop, land_area, pop_density) %>%
arrange(desc(pop_density)) %>%
head(10)
nhgis_final <- nhgis_clean %>%
mutate(
water_share = water_area / (land_area + water_area)
)
nhgis_final %>%
select(state_name, state_abbr, land_area, water_area, water_share) %>%
arrange(desc(water_share)) %>%
head(10)
